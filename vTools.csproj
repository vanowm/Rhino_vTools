<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net7.0-windows;net10.0-windows</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AssemblyName>vTools</AssemblyName>
    <Product>vTools</Product>
    <Title>vTools</Title>
    <RootNamespace>vTools</RootNamespace>
    <LangVersion>latest</LangVersion>
    <BuildInParallel>false</BuildInParallel>
    <ReleaseDllPaths>bin/Release/net7.0-windows/vTools.dll;bin/Release/net10.0-windows/vTools.dll</ReleaseDllPaths>
    <Rhino9SystemDirectory Condition="Exists('$(ProgramFiles)\Rhino 9\System\RhinoCommon.dll')">$(ProgramFiles)\Rhino 9\System</Rhino9SystemDirectory>
    <Rhino9SystemDirectory Condition="'$(Rhino9SystemDirectory)' == '' and Exists('$(ProgramFiles)\Rhino 9 WIP\System\RhinoCommon.dll')">$(ProgramFiles)\Rhino 9 WIP\System</Rhino9SystemDirectory>
    <RhinoSystemDirectory Condition="'$(TargetFramework)' == 'net7.0-windows'">$(ProgramFiles)\Rhino 8\System</RhinoSystemDirectory>
    <RhinoSystemDirectory Condition="'$(TargetFramework)' == 'net10.0-windows'">$(Rhino9SystemDirectory)</RhinoSystemDirectory>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' != ''">
    <FrameworkReference Include="Microsoft.WindowsDesktop.App" />

    <Reference Include="RhinoCommon">
      <HintPath>$(RhinoSystemDirectory)\RhinoCommon.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Eto">
      <HintPath>$(RhinoSystemDirectory)\Eto.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Rhino.UI">
      <HintPath>$(RhinoSystemDirectory)\Rhino.UI.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Content Include="vTools.config.json">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
      <CopyToPublishDirectory>Never</CopyToPublishDirectory>
    </Content>
    <Content Include="Toolbar\vTools.rui">
      <TargetPath>vTools.rui</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
  </ItemGroup>

  <Target Name="MergeRuntimeConfigDefaults" BeforeTargets="Build" Condition="'$(TargetFramework)' != ''">
    <Exec
      Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\MergeConfigDefaults.ps1&quot; -SourcePath &quot;$(MSBuildProjectDirectory)\vTools.config.json&quot; -DestinationPath &quot;$(TargetDir)vTools.config.json&quot;" />
  </Target>

  <Target Name="ValidateRhinoReferences" BeforeTargets="ResolveReferences" Condition="'$(TargetFramework)' != '' and !Exists('$(RhinoSystemDirectory)\RhinoCommon.dll')">
    <Error Text="$(TargetFramework) requires its matching Rhino installation; RhinoCommon.dll was not found under '$(RhinoSystemDirectory)'." />
  </Target>

  <Import Project="Build.Release.targets" />
</Project>
